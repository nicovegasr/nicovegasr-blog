---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostMeta from '@/features/posts/components/PostMeta.astro';
import RelatedPosts from '@/features/posts/components/RelatedPosts.astro';
import { getTranslator } from '@/i18n/translator';
import { buildPagePath, buildBlogPostPath } from '@/i18n/routes';
import {
  findAllPosts,
  findRelatedPosts,
  findRenderablePost,
} from '@/features/posts/post-repository';

const locale = 'en';

export async function getStaticPaths() {
  const posts = await findAllPosts('en');
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const renderable = slug ? await findRenderablePost(locale, slug) : null;
if (renderable === null) {
  throw new Error(`Post not found: ${locale}/${slug}`);
}

const { post, Content } = renderable;
const translate = getTranslator(locale);
const blogPath = buildPagePath('blog', locale);
const relatedPosts = await findRelatedPosts(locale, post.slug);
const alternatePaths = post.translationSlug
  ? { es: buildBlogPostPath('es', post.translationSlug) }
  : {};
---

<BaseLayout
  locale={locale}
  title={post.title}
  description={post.summary}
  openGraphType="article"
  alternatePaths={alternatePaths}
>
  <article class="reveal">
    <header class="article-header">
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href={blogPath}>{translate('navigation.blog')}</a> / {post.title}
      </nav>
      <h1>{post.title}</h1>
      <PostMeta post={post} />
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
  <RelatedPosts posts={relatedPosts} locale={locale} />
</BaseLayout>
