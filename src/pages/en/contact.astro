---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getTranslator } from '@/i18n/translator';

const locale = 'en';
const translate = getTranslator(locale);

// Links a pelo: URLs and handles, not editorial content. No backend, no form.
const links = [
  { label: 'Email', href: 'mailto:nicovegasr@gmail.com', handle: 'nicovegasr@gmail.com' },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/nicolas-vegas-rodriguez-07a4a5208/',
    handle: 'nicolas-vegas-rodriguez',
  },
  { label: 'GitHub', href: 'https://github.com/nicovegasr', handle: 'nicovegasr' },
  { label: 'Medium', href: 'https://medium.com/@nicovegasr', handle: '@nicovegasr' },
];
---

<BaseLayout
  locale={locale}
  title={`${translate('contact.heroTitle')} — ${translate('site.title')}`}
  description={translate('contact.metaDescription')}
>
  <section>
    <h1>{translate('contact.heroTitle')}</h1>
    <p>{translate('contact.lead')}</p>
    <dl>
      {
        links.map((link) => (
          <div>
            <dt>{link.label}</dt>
            <dd>
              <a href={link.href}>{link.handle}</a>
            </dd>
          </div>
        ))
      }
    </dl>
  </section>
</BaseLayout>
