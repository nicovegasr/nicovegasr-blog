---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PillRail from '@/features/pills/components/PillRail.astro';
import { getTranslator } from '@/i18n/translator';
import { buildPagePath, buildPillPath, buildPillSeriesPath } from '@/i18n/routes';
import { neighboringPills, pillLeafSlugOf } from '@/features/pills/pill';
import {
  findAllPublishedPills,
  findRenderablePill,
} from '@/features/pills/pill-repository';

const locale = 'en';

export async function getStaticPaths() {
  const pills = await findAllPublishedPills('en');
  return pills.map(({ series, pill }) => ({ params: { series, pill } }));
}

const { series, pill } = Astro.params;
const renderable =
  series && pill ? await findRenderablePill(locale, series, pill) : null;
if (renderable === null) {
  throw new Error(`Pill not found: ${locale}/${series}/${pill}`);
}

const { pill: currentPill, Content, seriesTitle, stops } = renderable;
const translate = getTranslator(locale);
const pillsPath = buildPagePath('pills', locale);
const seriesPath = buildPillSeriesPath(locale, currentPill.series);

const { previous, next } = neighboringPills(stops, currentPill.slug);

const alternatePaths = {
  es: buildPillPath('es', currentPill.series, pillLeafSlugOf(currentPill.slug)),
};
---

<BaseLayout
  locale={locale}
  title={`${currentPill.title} — ${seriesTitle}`}
  description={currentPill.subtitle}
  openGraphType="article"
  alternatePaths={alternatePaths}
>
  <article class="reveal">
    <header class="article-header">
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href={pillsPath}>{translate('pills.heading')}</a> /{' '}
        <a href={seriesPath}>{seriesTitle}</a> / {currentPill.title}
      </nav>
      <h1>{currentPill.title}</h1>
      <p class="pill-subtitle">{currentPill.subtitle}</p>
    </header>

    <PillRail
      stops={stops}
      hasSummary={false}
      series={currentPill.series}
      locale={locale}
      activePillSlug={currentPill.slug}
    />

    <div class="prose">
      <Content />
    </div>

    <nav class="pill-nav" aria-label="pills">
      {
        previous ? (
          <a
            href={buildPillPath(locale, previous.series, pillLeafSlugOf(previous.slug))}
          >
            {translate('pills.previous')} {previous.title}
          </a>
        ) : (
          <span />
        )
      }
      {
        next && (
          <a
            class="next"
            href={buildPillPath(locale, next.series, pillLeafSlugOf(next.slug))}
          >
            {next.title} {translate('pills.next')}
          </a>
        )
      }
    </nav>
  </article>
</BaseLayout>

<style>
  .pill-subtitle {
    color: var(--color-text-soft);
    font-size: var(--font-size-lead);
  }

  .pill-nav {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-rule);
    font-family: var(--font-family-display);
    font-size: var(--font-size-small);
  }

  .pill-nav a {
    text-decoration: none;
    color: var(--color-text-soft);
  }

  .pill-nav .next {
    margin-left: auto;
    text-align: right;
  }

  @media (hover: hover) {
    .pill-nav a:hover {
      color: var(--color-ink);
    }
  }
</style>
