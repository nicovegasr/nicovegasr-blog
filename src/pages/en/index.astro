---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostPreview from '@/features/posts/components/PostPreview.astro';
import PostSearch from '@/features/posts/components/PostSearch.astro';
import WritingSectionNav from '@/layouts/WritingSectionNav.astro';
import SocialLinks from '@/layouts/SocialLinks.astro';
import { getTranslator } from '@/i18n/translator';
import { buildPagePath } from '@/i18n/routes';
import { findAllPosts } from '@/features/posts/post-repository';

const locale = 'en';
const translate = getTranslator(locale);
const posts = await findAllPosts(locale);
---

<BaseLayout locale={locale}>
  <section class="intro reveal">
    <h1>{translate('blog.introTitle')}</h1>
    <p class="lead">
      {translate('blog.introText')}{' '}
      <a href={buildPagePath('about', locale)}>{translate('blog.introLink')}</a>
    </p>
    <SocialLinks />
  </section>
  <section class="reveal">
    <WritingSectionNav locale={locale} />
    {
      posts.length > 0 ? (
        <>
          <PostSearch locale={locale} posts={posts} />
          <ul class="post-list">
            {posts.map((post) => (
              <li>
                <PostPreview post={post} />
              </li>
            ))}
          </ul>
        </>
      ) : (
        <p class="lead">{translate('blog.empty')}</p>
      )
    }
  </section>
</BaseLayout>
