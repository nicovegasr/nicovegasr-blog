---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getTranslator } from '@/i18n/translator';
import { buildPagePath } from '@/i18n/routes';
import { findRenderableWork } from '@/features/work/work-repository';

const locale = 'es';
const translate = getTranslator(locale);

const renderable = await findRenderableWork(locale);
if (renderable === null) {
  throw new Error(`Work entry not found for locale: ${locale}`);
}
const { work, Content } = renderable;

const sinceLabel = new Intl.DateTimeFormat(locale, {
  month: 'long',
  year: 'numeric',
}).format(work.startDate);
const principlesPath = `${buildPagePath('about', locale)}#principles`;
---

<BaseLayout
  locale={locale}
  title={`${work.company} — ${translate('site.title')}`}
  description={translate('work.metaDescription')}
>
  <article>
    <header>
      <h1><a href={work.companyUrl}>{work.company}</a></h1>
      <p>{work.role} · {translate('work.since')} {sinceLabel} · {work.location}</p>
    </header>
    <Content />
    <p>
      {translate('work.valuesPrefix')}<a href={principlesPath}>{translate('work.valuesLink')}</a
      >{translate('work.valuesSuffix')}
    </p>
    <p><a href={work.companyUrl}>leanmind.es →</a></p>
  </article>
</BaseLayout>
