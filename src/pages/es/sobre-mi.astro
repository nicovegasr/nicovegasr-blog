---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LeanMindMark from '@/features/work/components/LeanMindMark.astro';
import TimelineEntry from '@/features/timeline/components/TimelineEntry.astro';
import { getTranslator } from '@/i18n/translator';
import { findAllPrinciples } from '@/features/principles/principle-repository';
import { findAllTimelineEntries } from '@/features/timeline/timeline-repository';
import { findAllProjects } from '@/features/projects/project-repository';
import { findRenderableWork } from '@/features/work/work-repository';

const locale = 'es';
const translate = getTranslator(locale);

const principles = await findAllPrinciples(locale);
const timeline = await findAllTimelineEntries(locale);
const projects = await findAllProjects(locale);

const renderableWork = await findRenderableWork(locale);
if (renderableWork === null) {
  throw new Error(`Work entry not found for locale: ${locale}`);
}
const { work, Content: WorkContent } = renderableWork;
const workSinceLabel = new Intl.DateTimeFormat(locale, {
  month: 'long',
  year: 'numeric',
}).format(work.startDate);

// Stack a pelo: nombres de tecnología sin traducir, categorías en inglés.
const stack = [
  { category: 'Languages', items: ['Java', 'Python', 'TypeScript', 'JavaScript', 'SQL'] },
  { category: 'Frameworks', items: ['Spring (Boot, Batch, Security)', 'Hibernate/JPA', 'React', 'Django', 'FastAPI'] },
  { category: 'Data', items: ['PostgreSQL', 'SQL Server', 'Oracle', 'MongoDB'] },
  { category: 'Cloud & DevOps', items: ['AWS', 'Docker', 'Jenkins', 'GitHub Actions', 'Nginx', 'Git'] },
  { category: 'Messaging', items: ['Kafka', 'RabbitMQ'] },
  { category: 'Architecture', items: ['Microservices', 'Hexagonal', 'DDD', 'CQRS', 'Event-driven'] },
  { category: 'Methodologies', items: ['TDD', 'Clean Architecture', 'SOLID', 'Agile/Scrum'] },
];
---

<BaseLayout
  locale={locale}
  title={`${translate('about.heroTitle')} — ${translate('site.title')}`}
  description={translate('about.metaDescription')}
>
  <section class="intro about-hero reveal">
    <img
      class="portrait"
      src="/nicolas-vegas.webp"
      width="480"
      height="480"
      loading="eager"
      alt="Foto de Nicolás Vegas"
    />
    <div class="about-hero-text">
      <h1>{translate('about.heroTitle')}</h1>
      <p class="lead">{translate('about.lead')}</p>
      <p class="lead">{translate('about.approach')}</p>
    </div>
  </section>

  <section id="principles" class="reveal">
    <h2>{translate('about.principlesTitle')}</h2>
    <ul class="principles">
      {principles.map((principle) => <li>{principle.title}</li>)}
    </ul>
  </section>

  <section class="reveal">
    <h2>{translate('about.stackTitle')}</h2>
    <dl class="stack">
      {
        stack.map((group) => (
          <div>
            <dt>{group.category}</dt>
            <dd>{group.items.join(' · ')}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  <section id="work" class="reveal">
    <h2>{translate('navigation.work')}</h2>
    <a class="work-now" href={work.companyUrl} target="_blank" rel="noopener">
      <LeanMindMark />
      <span class="work-now-text">
        <span class="work-now-company">{work.company}</span>
        <span class="work-now-meta label"
          >{work.role} · {translate('work.since')} {workSinceLabel} · {work.location}</span
        >
      </span>
    </a>
    <div class="prose work-now-body">
      <WorkContent />
      <p>
        {translate('work.valuesPrefix')}<a href="#principles">{translate('work.valuesLink')}</a
        >{translate('work.valuesSuffix')}
      </p>
    </div>
  </section>

  <section class="reveal">
    <h2>{translate('about.timelineTitle')}</h2>
    <ul class="timeline">
      {
        timeline.map((entry) => (
          <li>
            <TimelineEntry entry={entry} />
          </li>
        ))
      }
    </ul>
  </section>

  <section class="reveal">
    <h2>{translate('about.projectsTitle')}</h2>
    {
      projects.length > 0 ? (
        <ul class="projects">
          {projects.map((project) => (
            <li>
              <h3>{project.title}</h3>
              <p>{project.pitch}</p>
            </li>
          ))}
        </ul>
      ) : (
        <p class="lead">{translate('about.projectsEmpty')}</p>
      )
    }
  </section>
</BaseLayout>
