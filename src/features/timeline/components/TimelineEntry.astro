---
import type { TimelineEntry } from '@/features/timeline/timeline-entry';
import { getTranslator } from '@/i18n/translator';

interface Props {
  entry: TimelineEntry;
}

const { entry } = Astro.props;
const translate = getTranslator(entry.locale);

const formatMonthYear = (date: Date): string =>
  new Intl.DateTimeFormat(entry.locale, { month: 'short', year: 'numeric' }).format(date);

const startLabel = formatMonthYear(entry.startDate);
const startMachine = entry.startDate.toISOString().slice(0, 10);
const endLabel =
  entry.endDate === undefined
    ? translate('about.present')
    : formatMonthYear(entry.endDate);
const endMachine = entry.endDate?.toISOString().slice(0, 10);
---

<article class="timeline-entry">
  <p class="period">
    <time datetime={startMachine}>{startLabel}</time>
    {' – '}
    {
      endMachine === undefined ? (
        <span>{endLabel}</span>
      ) : (
        <time datetime={endMachine}>{endLabel}</time>
      )
    }
    {entry.sector !== undefined && <span>{' · '}{entry.sector}</span>}
  </p>
  <h3>{entry.company}</h3>
  <p class="role">{entry.role}</p>
  <p class="summary">{entry.summary}</p>
</article>

<style>
  .timeline-entry {
    position: relative;
    padding-left: var(--space-6);
    border-left: 2px solid var(--color-rule);
    padding-bottom: var(--space-8);
  }

  .timeline-entry::before {
    content: '';
    position: absolute;
    left: -7px;
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid var(--color-paper);
  }

  .period {
    font-family: var(--font-family-mono);
    font-size: var(--font-size-meta);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
  }

  .timeline-entry h3 {
    margin-top: var(--space-2);
    font-size: var(--font-size-heading-3);
  }

  .role {
    color: var(--color-text-soft);
    font-size: var(--font-size-small);
  }

  .summary {
    margin-top: var(--space-3);
    color: var(--color-text-soft);
  }
</style>
