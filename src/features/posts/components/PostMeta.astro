---
import type { Post } from '@/features/posts/post';
import ReadingTime from '@/features/posts/components/ReadingTime.astro';
import TagList from '@/features/posts/components/TagList.astro';

interface Props {
  post: Post;
}

const { post } = Astro.props;

const publicationDateLabel = new Intl.DateTimeFormat(post.locale, {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(post.publicationDate);
const publicationDateMachine = post.publicationDate.toISOString().slice(0, 10);
---

<div class="post-meta">
  <time datetime={publicationDateMachine}>{publicationDateLabel}</time>
  <span class="separator" aria-hidden="true">·</span>
  <ReadingTime minutes={post.readingTimeInMinutes} locale={post.locale} />
  <TagList tags={post.tags} />
</div>

<style>
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-3);
    font-family: var(--font-family-mono);
    font-size: var(--font-size-meta);
    color: var(--color-text-muted);
  }

  .post-meta time {
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .separator {
    color: var(--color-rule);
  }
</style>
