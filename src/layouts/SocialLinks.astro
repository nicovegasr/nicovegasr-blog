---
// Enlaces a plataformas como iconos. URLs/handles a pelo (no contenido editorial),
// mismo criterio que el stack. Sin backend ni formulario.
type Platform = 'email' | 'linkedin' | 'github' | 'medium';

interface SocialLink {
  platform: Platform;
  label: string;
  href: string;
}

const links: SocialLink[] = [
  { platform: 'email', label: 'Email', href: 'mailto:nicovegasr@gmail.com' },
  {
    platform: 'linkedin',
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/nicolas-vegas-rodriguez-07a4a5208/',
  },
  { platform: 'github', label: 'GitHub', href: 'https://github.com/nicovegasr' },
  { platform: 'medium', label: 'Medium', href: 'https://medium.com/@nicovegasr' },
];

const isExternal = (link: SocialLink): boolean => link.platform !== 'email';
---

<ul class="social-links">
  {
    links.map((link) => (
      <li>
        <a
          href={link.href}
          aria-label={link.label}
          title={link.label}
          rel={isExternal(link) ? 'me noopener' : undefined}
          target={isExternal(link) ? '_blank' : undefined}
        >
          {link.platform === 'email' && (
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linejoin="round"
                d="M3 6h18v12H3zM3 7l9 6 9-6"
              />
            </svg>
          )}
          {link.platform === 'linkedin' && (
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path
                fill="currentColor"
                d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"
              />
            </svg>
          )}
          {link.platform === 'github' && (
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path
                fill="currentColor"
                d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.3-1.8-1.3-1.8-1.1-.7 0-.7 0-.7 1.2 0 1.9 1.2 1.9 1.2 1 1.8 2.8 1.3 3.5 1 0-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.3 1.2-3.2 0-.3-.5-1.5.2-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.7 1.7.2 2.9.1 3.2.8.9 1.2 1.9 1.2 3.2 0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"
              />
            </svg>
          )}
          {link.platform === 'medium' && (
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path
                fill="currentColor"
                d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12zm7.42 0c0 3.54-1.51 6.42-3.38 6.42s-3.38-2.88-3.38-6.42 1.52-6.42 3.38-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75s-1.19-2.58-1.19-5.75.53-5.75 1.19-5.75S24 8.83 24 12z"
              />
            </svg>
          )}
        </a>
      </li>
    ))
  }
</ul>

<style>
  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .social-links a {
    display: inline-grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-medium);
    color: var(--color-ink);
    transition:
      color var(--motion-duration-fast) var(--motion-easing),
      background var(--motion-duration-fast) var(--motion-easing),
      border-color var(--motion-duration-fast) var(--motion-easing),
      transform var(--motion-duration-fast) var(--motion-easing);
  }

  @media (hover: hover) {
    .social-links a:hover {
      color: var(--color-accent-ink);
      background: var(--color-accent);
      border-color: var(--color-accent);
      transform: translateY(-2px);
    }
  }
</style>
