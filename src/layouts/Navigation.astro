---
import type { Locale } from '@/i18n/locale';
import { buildPagePath } from '@/i18n/routes';
import { getTranslator } from '@/i18n/translator';
import LanguageSwitcher from '@/layouts/LanguageSwitcher.astro';
import ThemeToggle from '@/layouts/ThemeToggle.astro';
import Logo from '@/layouts/Logo.astro';

interface Props {
  locale: Locale;
  alternatePaths?: Partial<Record<Locale, string>>;
}

const { locale, alternatePaths = {} } = Astro.props;
const translate = getTranslator(locale);

// "Dónde trabajo" no es página propia: es una sección de "sobre mí" (ancla #work).
// El contacto vive en el footer (todas las páginas) y en el hero de la home.
const aboutPath = buildPagePath('about', locale);
const blogPath = buildPagePath('blog', locale);

const navigationItems: { href: string; label: string }[] = [
  { href: blogPath, label: translate('navigation.blog') },
  { href: buildPagePath('projects', locale), label: translate('navigation.projects') },
  { href: aboutPath, label: translate('navigation.about') },
  { href: `${aboutPath}#work`, label: translate('navigation.work') },
];

const homePath = blogPath;

// Apuntes y Píldoras son sub-secciones del Blog (no ítems del header): estando
// en ellas el ítem activo sigue siendo Blog, así que su ruta colapsa a blogPath.
const blogSectionPaths = [blogPath, buildPagePath('notes', locale), buildPagePath('pills', locale)];
const activePath = blogSectionPaths.includes(Astro.url.pathname) ? blogPath : Astro.url.pathname;
---

<header class="site-header">
  <div class="bar">
    <a class="brand" href={homePath} aria-label={translate('site.title')}>
      <Logo size={34} title={translate('site.title')} />
      <span class="brand-name">nicovegasr</span>
    </a>

    <nav class="primary" id="site-nav" aria-label="Primary">
      <ul>
        {
          navigationItems.map(({ href, label }) => {
            const isCurrentPage = href === activePath;
            return (
              <li>
                <a
                  href={href}
                  class={isCurrentPage ? 'current' : undefined}
                  aria-current={isCurrentPage ? 'page' : undefined}
                >
                  {label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <div class="actions">
      <LanguageSwitcher locale={locale} alternatePaths={alternatePaths} />
      <ThemeToggle locale={locale} />
      <button
        type="button"
        class="menu-toggle"
        aria-label={translate('navigation.menu')}
        aria-controls="site-nav"
        aria-expanded="false"
      >
        <svg class="icon-open" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
        <svg class="icon-close" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('.site-header');
  const toggle = header?.querySelector<HTMLButtonElement>('.menu-toggle');
  const nav = header?.querySelector<HTMLElement>('.primary');

  const closeMenu = () => {
    header?.removeAttribute('data-menu-open');
    toggle?.setAttribute('aria-expanded', 'false');
  };

  toggle?.addEventListener('click', () => {
    const isOpen = header?.toggleAttribute('data-menu-open') ?? false;
    toggle.setAttribute('aria-expanded', String(isOpen));
  });

  // Cerrar al navegar, con Escape o al tocar fuera del header.
  nav?.addEventListener('click', (event) => {
    if ((event.target as HTMLElement).closest('a')) closeMenu();
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && header?.hasAttribute('data-menu-open')) {
      closeMenu();
      toggle?.focus();
    }
  });

  document.addEventListener('click', (event) => {
    if (header?.hasAttribute('data-menu-open') && !header.contains(event.target as Node)) {
      closeMenu();
    }
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--color-paper) 85%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-rule);
  }

  .bar {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    max-width: var(--content-width-wide);
    margin-inline: auto;
    padding: var(--space-4) var(--space-6);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    font-family: var(--font-family-display);
    font-weight: 700;
  }

  .brand-name {
    font-size: var(--font-size-base);
  }

  .primary {
    margin-inline-start: auto;
  }

  .primary ul {
    display: flex;
    gap: var(--space-6);
    list-style: none;
    padding: 0;
  }

  .primary a {
    font-family: var(--font-family-display);
    font-size: var(--font-size-base);
    font-weight: 500;
    text-decoration: none;
    color: var(--color-text-soft);
    padding-bottom: 2px;
    transition: color var(--motion-duration-fast) var(--motion-easing);
  }

  @media (hover: hover) {
    .primary a:hover {
      color: var(--color-ink);
    }
  }

  .primary a.current {
    color: var(--color-accent-ink);
    background: var(--color-accent);
    padding: 0.3em 0.7em;
    border-radius: var(--radius-medium);
  }

  .actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* Botón hamburguesa: solo visible en móvil. */
  .menu-toggle {
    display: none;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-medium);
    background: transparent;
    color: var(--color-ink);
    cursor: pointer;
  }

  .menu-toggle .icon-close {
    display: none;
  }

  .menu-toggle[aria-expanded='true'] .icon-open {
    display: none;
  }

  .menu-toggle[aria-expanded='true'] .icon-close {
    display: block;
  }

  @media (max-width: 640px) {
    /* Header en una sola fila compacta: máxima zona de lectura. */
    .bar {
      gap: var(--space-3);
      padding: var(--space-3) var(--space-4);
    }

    .brand {
      margin-inline-end: auto;
    }

    .brand-name {
      font-size: var(--font-size-small);
    }

    .menu-toggle {
      display: inline-grid;
    }

    /* El nav sale del flujo → no empuja el header; se despliega como overlay. */
    .primary {
      position: absolute;
      inset-inline: 0;
      top: 100%;
      margin-inline-start: 0;
      display: none;
      background: var(--color-paper);
      border-bottom: 1px solid var(--color-rule);
      box-shadow: 0 8px 24px rgb(0 0 0 / 0.12);
    }

    .site-header[data-menu-open] .primary {
      display: block;
    }

    .primary ul {
      flex-direction: column;
      gap: 0;
      max-width: var(--content-width-wide);
      margin-inline: auto;
      padding: var(--space-2) var(--space-4) var(--space-4);
    }

    .primary li + li {
      border-top: 1px solid var(--color-rule);
    }

    .primary a {
      display: block;
      padding: var(--space-3) 0;
      font-size: var(--font-size-base);
    }

    .primary a.current {
      display: inline-block;
    }
  }
</style>
