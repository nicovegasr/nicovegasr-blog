---
import type { Locale } from '@/i18n/locale';
import { LOCALES, DEFAULT_LOCALE, OPEN_GRAPH_LOCALE } from '@/i18n/locale';
import { getTranslator } from '@/i18n/translator';
import { buildAlternateLocalePath, localesOtherThan, buildRssFeedPath } from '@/i18n/routes';
import Navigation from '@/layouts/Navigation.astro';
import Footer from '@/layouts/Footer.astro';

import '@fontsource-variable/space-grotesk/wght.css';
import '@fontsource-variable/inter/wght.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@/styles/tokens.css';
import '@/styles/base.css';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  openGraphType?: 'website' | 'article';
}

const { locale, title, description, openGraphType = 'website' } = Astro.props;
const translate = getTranslator(locale);

const documentTitle = title ?? translate('site.title');
const documentDescription = description ?? translate('site.description');
const siteName = translate('site.title');

const currentPathname = Astro.url.pathname;
const toAbsoluteUrl = (path: string): string => new URL(path, Astro.site).toString();
const canonicalUrl = toAbsoluteUrl(currentPathname);
const pathForLocale = (target: Locale): string =>
  target === locale
    ? currentPathname
    : buildAlternateLocalePath(currentPathname, locale, target);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Antes del primer pintado: marca que hay JS (gatea las animaciones de
      // aparición; sin JS el contenido se ve) y fija el tema para evitar parpadeo.
      document.documentElement.classList.add('js');
      const storedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = storedTheme ?? (prefersDark ? 'dark' : 'light');
      document.documentElement.dataset.theme = theme;
    </script>
    <title>{documentTitle}</title>
    <meta name="description" content={documentDescription} />
    <link rel="canonical" href={canonicalUrl} />
    {
      LOCALES.map((target) => (
        <link rel="alternate" hreflang={target} href={toAbsoluteUrl(pathForLocale(target))} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={toAbsoluteUrl(pathForLocale(DEFAULT_LOCALE))} />

    <meta property="og:type" content={openGraphType} />
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={documentDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={OPEN_GRAPH_LOCALE[locale]} />
    {
      localesOtherThan(locale).map((target) => (
        <meta property="og:locale:alternate" content={OPEN_GRAPH_LOCALE[target]} />
      ))
    }

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={documentTitle} />
    <meta name="twitter:description" content={documentDescription} />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteName}
      href={toAbsoluteUrl(buildRssFeedPath(locale))}
    />
  </head>
  <body>
    <Navigation locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />

    <script>
      // Aparición al entrar en viewport. Si no hay soporte, todo queda visible.
      const revealItems = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window && revealItems.length > 0) {
        const observer = new IntersectionObserver(
          (entries, self) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                self.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px' },
        );
        revealItems.forEach((item) => observer.observe(item));
      } else {
        revealItems.forEach((item) => item.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
