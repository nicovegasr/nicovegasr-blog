---
import type { Locale } from '@/i18n/locale';
import { buildAlternateLocalePath, localesOtherThan } from '@/i18n/routes';
import { getTranslator } from '@/i18n/translator';

interface Props {
  locale: Locale;
  alternatePaths?: Partial<Record<Locale, string>>;
}

const { locale, alternatePaths = {} } = Astro.props;
const currentPathname = Astro.url.pathname;
// The label shows the CURRENT language (not the one you'd switch to): it reads
// as a language indicator that happens to be clickable, not a "go to X" link.
const currentLanguageLabel = getTranslator(locale)('language.current');
---

<ul class="language-switcher">
  {
    localesOtherThan(locale).map((target) => {
      const href = alternatePaths[target] ?? buildAlternateLocalePath(currentPathname, locale, target);
      return (
        <li>
          <a href={href} lang={target}>
            {currentLanguageLabel}
          </a>
        </li>
      );
    })
  }
</ul>

<style>
  .language-switcher {
    display: flex;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .language-switcher a {
    display: inline-block;
    font-family: var(--font-family-mono);
    font-size: var(--font-size-meta);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    color: var(--color-text-muted);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-medium);
    transition:
      color var(--motion-duration-fast) var(--motion-easing),
      border-color var(--motion-duration-fast) var(--motion-easing);
  }

  @media (hover: hover) {
    .language-switcher a:hover {
      color: var(--color-ink);
      border-color: var(--color-ink);
    }
  }
</style>
